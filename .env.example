# Dashboard base URL (no trailing slash). Server routes call the dashboard from here.
SPLITPAY_API_URL=http://localhost:3000
NEXT_PUBLIC_SPLITPAY_API_URL=http://localhost:3000

# Same value on the dashboard (.env) as DEMO_STORE_SECRET — lets simulated store checkout
# create a transaction + bell notification for the customer (split code) on the dashboard.
DEMO_STORE_SECRET=local-demo-change-me
